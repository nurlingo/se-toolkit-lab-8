{
  "agents": {
    "defaults": {
      "workspace": "./workspace",
      "model": "coder-model",
      "provider": "custom",
      "maxTokens": 8192,
      "temperature": 0.1,
      "maxToolIterations": 40
    }
  },
  "channels": {},
  "providers": {
    "custom": {
      "apiKey": "my-secret-qwen-key",
      "apiBase": "http://localhost:42005/v1"
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790
  },
  "tools": {
    "exec": {
      "enable": true,
      "timeout": 60
    },
    "restrictToWorkspace": false,
    "mcpServers": {
      "lms": {
        "type": "stdio",
        "command": "python",
        "args": [
          "-m",
          "mcp_lms"
        ],
        "env": {
          "NANOBOT_LMS_BACKEND_URL": "http://localhost:42002",
          "NANOBOT_LMS_API_KEY": "test-api-key-123"
        }
      }
    }
  }
}